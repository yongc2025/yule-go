# yule-go 环境变量配置
# 复制此文件为 .env 并填入实际值

# ========== 必填项（生产环境必须设置） ==========

# JWT 密钥（至少 32 字符，生产环境务必更换）
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# 数据库密码
DB_PASSWORD=your-database-password

# ========== 可选项 ==========

# 数据库主机（默认 127.0.0.1）
# DB_HOST=127.0.0.1

# Gin 模式：debug / release / test（生产环境设为 release）
# GIN_MODE=release

# 微信支付配置（接入微信支付时填写）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_MCH_ID=
# WECHAT_MCH_KEY=
# WECHAT_NOTIFY_URL=

/* 全局样式 — 设计稿色彩体系 */
page {
  background-color: #F5F5F0;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1B1B1B;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #2D6A4F, #40916C);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-blue {
  background: #D8F3DC;
  color: #2D6A4F;
}

.tag-green {
  background: #D8F3DC;
  color: #2D6A4F;
}

.tag-orange {
  background: #FFF3E8;
  color: #E76F51;
}

.tag-red {
  background: #FFF1F0;
  color: #E63946;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

/* 价格 */
.price {
  color: #E76F51;
  font-weight: 700;
}

.price-unit {
  font-size: 22rpx;
  font-weight: 400;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

/* pages/member/records.wxss */

.page {
  padding-bottom: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计摘要 */
.summary {
  padding: 24rpx 32rpx;
  font-size: 24rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  padding: 0 24rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.record-left {
  margin-right: 20rpx;
}

.record-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0FFF4;
  border-radius: 50%;
}

.record-center {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.record-gifts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.gift-tag {
  font-size: 22rpx;
  color: #E76F51;
  background: #FFF8F0;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.record-time {
  font-size: 22rpx;
  color: #bbb;
}

.record-right {
  text-align: right;
  margin-left: 16rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
  margin-bottom: 6rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.status-paid {
  color: #2D6A4F;
  background: #F0FFF4;
}

.status-refunded {
  color: #999;
  background: #f5f5f5;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #E76F51, #F4845F);
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

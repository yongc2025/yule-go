<!--pages/admin/schedules.wxml-->
<!--团期管理-->

<view class="page">
  <view class="top-bar">
    <view class="top-title">{{activityName}}</view>
    <view class="btn-add" bindtap="showCreateForm">+ 新建团期</view>
  </view>

  <!-- 团期列表 -->
  <view class="list" wx:if="{{schedules.length > 0}}">
    <view class="card" wx:for="{{schedules}}" wx:key="_id">
      <view class="card-header">
        <view class="card-date">📅 {{item.dateFormatted}}</view>
        <view class="card-tag status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="card-body">
        <view class="card-info">
          <text>👥 {{item.bookedSlots || 0}}/{{item.maxSlots}} 已报名</text>
          <text class="slots-left" wx:if="{{item.slotsLeft <= 3 && item.slotsLeft > 0}}">（仅剩 {{item.slotsLeft}} 位）</text>
        </view>
        <!-- 名额进度条 -->
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.bookedSlots / item.maxSlots * 100}}%; background: {{item.slotsLeft <= 0 ? '#e74c3c' : item.slotsLeft <= 3 ? '#f39c12' : '#2D6A4F'}}"></view>
        </view>
      </view>
      <view class="card-actions" wx:if="{{item.status === 'active'}}">
        <view class="btn-sm btn-danger" bindtap="cancelSchedule" data-id="{{item._id}}">取消团期</view>
      </view>
      <view class="card-actions" wx:if="{{item.status === 'cancelled'}}">
        <view class="btn-sm btn-danger" bindtap="deleteSchedule" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && schedules.length === 0}}">
    <view class="empty-icon">📅</view>
    <view>暂无团期</view>
    <view class="empty-sub">点击右上角创建第一个团期</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 新建弹窗 -->
  <view class="modal" wx:if="{{showForm}}" bindtap="closeForm">
    <view class="modal-content" catchtap="">
      <view class="modal-title">新建团期</view>

      <view class="form-group">
        <view class="form-label">出行日期</view>
        <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
          <view class="form-input picker-value">{{form.date || '请选择日期'}}</view>
        </picker>
      </view>

      <view class="form-group">
        <view class="form-label">名额上限</view>
        <input class="form-input" type="number" placeholder="20" value="{{form.maxSlots}}" bindinput="onInputMaxSlots" />
      </view>

      <view class="modal-actions">
        <view class="btn-cancel" bindtap="closeForm">取消</view>
        <view class="btn-confirm" bindtap="submitForm">创建</view>
      </view>
    </view>
  </view>
</view>

<!--pages/admin/schedules.wxml-->
<!--团期管理 — 支持批量创建 + 编辑(日期/名额/集合地点) + 取消退款-->

<view class="page">
  <view class="top-bar">
    <view class="top-title">{{activityName}}</view>
    <view class="top-actions">
      <view class="btn-log" bindtap="showChangelog">📋 记录</view>
      <view class="btn-add" bindtap="showCreateForm">+ 新建团期</view>
    </view>
  </view>

  <!-- 团期列表 -->
  <view class="list" wx:if="{{schedules.length > 0}}">
    <view class="card" wx:for="{{schedules}}" wx:key="_id">
      <view class="card-header">
        <view class="card-date">📅 {{item.dateFormatted}}</view>
        <view class="card-tag status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="card-body">
        <view class="card-info">
          <text>👥 {{item.bookedSlots || 0}}/{{item.maxSlots}} 已报名</text>
          <text class="slots-left" wx:if="{{item.slotsLeft <= 3 && item.slotsLeft > 0}}">（仅剩 {{item.slotsLeft}} 位）</text>
        </view>
        <view class="card-location" wx:if="{{item.hasLocation}}">
          <text>📍 {{item.location}}</text>
        </view>
        <view class="card-cancel-reason" wx:if="{{item.status === 'cancelled' && item.cancelReason}}">
          <text>原因：{{item.cancelReason}}</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.bookedSlots / item.maxSlots * 100}}%; background: {{item.slotsLeft <= 0 ? '#e74c3c' : item.slotsLeft <= 3 ? '#f39c12' : '#2D6A4F'}}"></view>
        </view>
      </view>
      <view class="card-actions" wx:if="{{item.status === 'active'}}">
        <view class="btn-sm" bindtap="editSchedule" data-id="{{item._id}}">✏️ 编辑</view>
        <view class="btn-sm btn-danger" bindtap="cancelSchedule" data-id="{{item._id}}">取消团期</view>
      </view>
      <view class="card-actions" wx:if="{{item.status === 'cancelled'}}">
        <view class="btn-sm btn-danger" bindtap="deleteSchedule" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && schedules.length === 0}}">
    <view class="empty-icon">📅</view>
    <view>暂无团期</view>
    <view class="empty-sub">点击右上角批量创建团期</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <!-- 新建/编辑弹窗 -->
  <view class="modal" wx:if="{{showForm}}" bindtap="closeForm">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{editId ? '编辑团期' : '批量创建团期'}}</view>

      <!-- 编辑模式：单日期 -->
      <block wx:if="{{editId}}">
        <view class="form-group">
          <view class="form-label">出行日期</view>
          <picker mode="date" value="{{form.date}}" bindchange="onDateChange"
                  bindtap="onPickerOpen" bindcolumnchange="onPickerOpen">
            <view class="form-input picker-value">{{form.date || '请选择日期'}}</view>
          </picker>
        </view>
      </block>

      <!-- 新建模式：多日期 -->
      <block wx:else>
        <view class="form-group">
          <view class="form-label">选择日期（可多选）</view>
          <view class="date-tags" wx:if="{{form.dates.length > 0}}">
            <view class="date-tag" wx:for="{{form.dates}}" wx:key="*this">
              <text>{{item}}</text>
              <view class="date-tag-remove" catchtap="removeDate" data-index="{{index}}">✕</view>
            </view>
          </view>
          <view class="date-add-row">
            <picker mode="date" value="{{tempDate}}" bindchange="onTempDateChange"
                    bindtap="onPickerOpen" bindcolumnchange="onPickerOpen">
              <view class="btn-add-date">+ 添加日期</view>
            </picker>
            <view class="quick-dates">
              <view class="btn-quick" bindtap="addNextWeekends">+近4周周末</view>
            </view>
          </view>
        </view>
      </block>

      <view class="form-group">
        <view class="form-label">名额上限</view>
        <input class="form-input" type="number" placeholder="20" value="{{form.maxSlots}}" bindinput="onInputMaxSlots" />
      </view>

      <view class="form-group">
        <view class="form-label">集合地点（选填）</view>
        <input class="form-input" placeholder="如：XX公园南门" value="{{form.location}}" bindinput="onInputLocation" />
      </view>

      <view class="modal-actions">
        <view class="btn-cancel" bindtap="closeForm">取消</view>
        <view class="btn-confirm" bindtap="submitForm">
          {{editId ? '保存' : '创建 ' + form.dates.length + ' 个团期'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 变更记录弹窗 -->
  <view class="modal" wx:if="{{showChangelog}}" bindtap="closeChangelog">
    <view class="modal-content modal-wide" catchtap="">
      <view class="modal-title">📋 变更记录</view>
      <view class="changelog-list" wx:if="{{changelog.length > 0}}">
        <view class="changelog-item" wx:for="{{changelog}}" wx:key="_id">
          <view class="changelog-header">
            <text class="changelog-type">{{item.typeText}}</text>
            <text class="changelog-time">{{item.timeFormatted}}</text>
          </view>
          <view class="changelog-activity">{{item.activityName}}</view>
          <view class="changelog-changes" wx:for="{{item.changes}}" wx:for-item="change" wx:key="*this">
            <text>• {{change}}</text>
          </view>
        </view>
      </view>
      <view class="changelog-empty" wx:else>
        <text>暂无变更记录</text>
      </view>
      <view class="modal-actions">
        <view class="btn-cancel" style="flex:1;" bindtap="closeChangelog">关闭</view>
      </view>
    </view>
  </view>
</view>

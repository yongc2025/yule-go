/* pages/admin/finance.wxss */

.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 40rpx; }

/* 时间范围 */
.range-tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}
.range-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}
.range-tab.active {
  background: #2D6A4F;
  color: #fff;
  font-weight: 600;
}

/* 卡片 */
.card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 收支概览 */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.summary-item {
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}
.summary-item.income { background: #D8F3DC; }
.summary-item.refund { background: #FFF3E0; }
.summary-label { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.summary-num { font-size: 40rpx; font-weight: 700; }
.summary-item.income .summary-num { color: #2D6A4F; }
.summary-item.refund .summary-num { color: #E76F51; }
.summary-count { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.net-income {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}
.net-label { font-size: 28rpx; font-weight: 600; color: #333; }
.net-num { font-size: 36rpx; font-weight: 700; }
.net-num.positive { color: #2D6A4F; }
.net-num.negative { color: #e74c3c; }

.summary-footer {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
}
.footer-item { font-size: 24rpx; color: #999; }

/* 按团期对账 */
.schedule-stats { }
.schedule-stat-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.schedule-stat-item:last-child { border-bottom: none; }
.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.stat-name { font-size: 28rpx; font-weight: 600; color: #333; }
.stat-date { font-size: 24rpx; color: #999; }
.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 4rpx 0;
}
.stat-label { font-size: 26rpx; color: #666; }
.stat-value { font-size: 26rpx; font-weight: 600; }
.income-text { color: #2D6A4F; }
.refund-text { color: #E76F51; }
.net-row { margin-top: 8rpx; padding-top: 8rpx; border-top: 1rpx dashed #f0f0f0; }

/* 退款入口 */
.refund-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.refund-entry-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.refund-icon { font-size: 36rpx; }
.refund-title { font-size: 30rpx; font-weight: 600; }
.refund-count {
  font-size: 22rpx;
  background: #FFF3E0;
  color: #E76F51;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.refund-arrow { font-size: 24rpx; color: #999; }

/* 退款列表 */
.refund-list { margin-top: 20rpx; }
.refund-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.refund-item:last-child { border-bottom: none; }
.refund-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.refund-order-no { font-size: 26rpx; color: #666; }
.refund-amount { font-size: 28rpx; font-weight: 600; color: #E76F51; }
.refund-body {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.refund-activity { font-size: 28rpx; font-weight: 600; color: #333; }
.refund-time { font-size: 24rpx; color: #999; }
.refund-reason { font-size: 24rpx; color: #999; }

.load-more {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #2D6A4F;
}

.loading { text-align: center; padding: 60rpx; color: #999; font-size: 26rpx; }
.empty-sub { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }

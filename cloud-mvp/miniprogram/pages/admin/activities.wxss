.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.top-title { font-size: 36rpx; font-weight: bold; color: #333; }
.btn-add { background: #2D6A4F; color: #fff; padding: 12rpx 28rpx; border-radius: 12rpx; font-size: 28rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; }
.card-tag { font-size: 24rpx; background: #e8f5e9; color: #2D6A4F; padding: 4rpx 16rpx; border-radius: 8rpx; }
.card-body { margin-bottom: 20rpx; }
.card-info { font-size: 26rpx; color: #666; margin-bottom: 8rpx; }
.card-meta { display: flex; gap: 16rpx; margin-top: 8rpx; }
.meta-item { font-size: 22rpx; color: #999; background: #f5f5f5; padding: 4rpx 12rpx; border-radius: 6rpx; }
.card-actions { display: flex; gap: 16rpx; border-top: 1rpx solid #f0f0f0; padding-top: 20rpx; }
.btn-sm { flex: 1; text-align: center; font-size: 26rpx; padding: 12rpx 0; background: #f5f5f5; border-radius: 8rpx; color: #333; }
.btn-danger { color: #e74c3c; }
.empty { text-align: center; padding: 120rpx 0; color: #999; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-sub { font-size: 24rpx; color: #bbb; margin-top: 8rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; font-size: 26rpx; }

/* pages/admin/shop.wxss */
.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }

.section { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.section-hint { font-size: 24rpx; color: #999; margin-bottom: 20rpx; }

.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; }
.required { color: #e74c3c; }
.form-input { border: 1rpx solid #e0e0e0; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #333; background: #fafafa; }
.form-input:focus { border-color: #2D6A4F; background: #fff; }

/* 封面图 */
.cover-row { display: flex; align-items: center; gap: 20rpx; }
.cover-preview { width: 200rpx; height: 120rpx; border-radius: 12rpx; }
.cover-upload { width: 200rpx; height: 120rpx; border: 2rpx dashed #ccc; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fafafa; }
.upload-icon { font-size: 40rpx; color: #999; }
.upload-text { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 头像 */
.avatar-row { display: flex; align-items: center; gap: 20rpx; }
.avatar-preview { width: 120rpx; height: 120rpx; border-radius: 50%; }
.avatar-upload { width: 120rpx; height: 120rpx; border: 2rpx dashed #ccc; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fafafa; }

/* 标签 */
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.tag-item { display: flex; align-items: center; gap: 8rpx; background: #e8f5e9; color: #2D6A4F; padding: 8rpx 20rpx; border-radius: 24rpx; font-size: 26rpx; }
.tag-remove { font-size: 20rpx; color: #999; padding: 4rpx; }
.preset-tags { margin-bottom: 20rpx; }
.preset-label { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.preset-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.preset-tag { padding: 8rpx 20rpx; border: 1rpx solid #ddd; border-radius: 24rpx; font-size: 24rpx; color: #666; background: #fafafa; }
.preset-tag.added { border-color: #2D6A4F; color: #2D6A4F; background: #e8f5e9; }
.custom-input-row { display: flex; gap: 16rpx; align-items: center; }
.btn-add-tag { background: #2D6A4F; color: #fff; padding: 16rpx 28rpx; border-radius: 12rpx; font-size: 26rpx; white-space: nowrap; }
.flex1 { flex: 1; }

/* 相册 */
.image-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.image-item { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.img-delete { position: absolute; top: 0; right: 0; width: 48rpx; height: 48rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 24rpx; display: flex; align-items: center; justify-content: center; border-bottom-left-radius: 12rpx; }
.image-add { width: 200rpx; height: 200rpx; border: 2rpx dashed #ccc; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fafafa; }
.add-icon { font-size: 56rpx; color: #999; line-height: 1; }
.add-text { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* 底部 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 32rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); z-index: 100; }
.btn-save { width: 100%; height: 88rpx; background: #2D6A4F; color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.btn-save.disabled { opacity: 0.6; pointer-events: none; }

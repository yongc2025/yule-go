<!--pages/admin/admin.wxml-->
<!--管理入口 — 老板专用-->

<view class="page">
  <!-- 未登录/非管理员提示 -->
  <view class="admin-login" wx:if="{{!isAdmin}}">
    <view class="empty-icon">🔐</view>
    <view class="login-title">店主管理入口</view>
    <view class="login-desc">请输入管理密码以进入</view>
    <input class="login-input" type="text" password placeholder="请输入密码" value="{{password}}" bindinput="onInputPassword" />
    <view class="btn-primary" bindtap="loginAdmin" style="margin-top: 32rpx;">进入管理</view>
  </view>

  <!-- 管理面板 -->
  <view class="admin-panel" wx:if="{{isAdmin}}">
    <!-- 今日概览 -->
    <view class="card overview-card">
      <view class="section-title">📊 今日概览</view>
      <view class="overview-grid">
        <view class="overview-item">
          <view class="overview-num">{{stats.todayOrders}}</view>
          <view class="overview-label">今日订单</view>
        </view>
        <view class="overview-item">
          <view class="overview-num">¥{{stats.todayRevenue}}</view>
          <view class="overview-label">今日营收</view>
        </view>
        <view class="overview-item">
          <view class="overview-num">{{stats.pendingCheckin}}</view>
          <view class="overview-label">待核销</view>
        </view>
        <view class="overview-item">
          <view class="overview-num">{{stats.weekSchedules}}</view>
          <view class="overview-label">本周团期</view>
        </view>
      </view>
    </view>

    <!-- 管理入口 -->
    <view class="card">
      <view class="menu-item" bindtap="goActivities">
        <view class="menu-icon">📋</view>
        <view class="menu-text">
          <view class="menu-title">活动管理</view>
          <view class="menu-desc">创建/编辑活动和团期</view>
        </view>
        <view class="menu-arrow">▶</view>
      </view>
    </view>

    <!-- 核销入口 -->
    <view class="card">
      <view class="menu-item" bindtap="goCheckin">
        <view class="menu-icon">📱</view>
        <view class="menu-text">
          <view class="menu-title">扫码核销</view>
          <view class="menu-desc">扫描用户核销码，确认到场</view>
        </view>
        <view class="menu-arrow">▶</view>
      </view>

      <!-- 手动输入核销码 -->
      <view class="checkin-manual">
        <view class="checkin-divider">
          <view class="divider-line"></view>
          <text class="divider-text">或手动输入核销码</text>
          <view class="divider-line"></view>
        </view>
        <view class="checkin-input-row">
          <input class="checkin-input" type="number" maxlength="6" placeholder="输入6位核销码" value="{{checkinCode}}" bindinput="onInputCheckinCode" />
          <view class="btn-checkin" bindtap="manualCheckin">核销</view>
        </view>
      </view>
    </view>

    <!-- 今日团期 -->
    <view class="card">
      <view class="section-title">📅 今日团期</view>
      <view class="schedule-list" wx:if="{{todaySchedules.length > 0}}">
        <view class="schedule-item" wx:for="{{todaySchedules}}" wx:key="_id">
          <view class="schedule-name">{{item.activityName}}</view>
          <view class="schedule-info">
            <text>已报名 {{item.bookedSlots}}/{{item.maxSlots}}</text>
            <text class="checkin-progress">已核销 {{item.checkedIn || 0}}</text>
          </view>
        </view>
      </view>
      <view class="empty-sub" wx:else>今日无团期</view>
    </view>

    <!-- 最近订单 -->
    <view class="card">
      <view class="section-title">📋 最近订单</view>
      <view class="order-mini-list" wx:if="{{recentOrders.length > 0}}">
        <view class="order-mini" wx:for="{{recentOrders}}" wx:key="_id">
          <view class="order-mini-info">
            <text class="order-mini-name">{{item.contactName}}</text>
            <text class="order-mini-activity">{{item.activityName}}</text>
          </view>
          <view class="order-mini-right">
            <text class="price">¥{{item.totalFee}}</text>
            <text class="order-mini-status status-{{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
      </view>
      <view class="empty-sub" wx:else>暂无订单</view>
    </view>
  </view>
</view>

/* pages/booking/booking.wxss */

.summary-card {
  background: linear-gradient(135deg, #D8F3DC, #EDF7EF);
}

.summary-name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.summary-meta {
  display: flex;
  gap: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 人数选择器 */
.counter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.counter-row:last-child {
  border-bottom: none;
}

.counter-label {
  display: flex;
  flex-direction: column;
}

.counter-price {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.counter-btns {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.counter-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.counter-num {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

/* 表单 */
.form-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  padding: 8rpx 0;
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  box-sizing: border-box;
}

/* 费用明细 */
.fee-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #666;
}

.fee-row.total {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 同行优惠 */
.discount-row {
  background: #FFF8F0;
  margin: 8rpx -16rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.discount-label {
  display: flex;
  flex-direction: column;
}

.discount-tag {
  font-size: 26rpx;
  color: #E76F51;
  font-weight: 600;
}

.discount-rule {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.discount-amount {
  color: #E76F51;
  font-weight: 600;
  font-size: 28rpx;
}

.gift-row {
  padding: 4rpx 0;
}

.gift-text {
  font-size: 24rpx;
  color: #2D6A4F;
  font-weight: 500;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.bottom-total {
  display: flex;
  align-items: baseline;
}

.bottom-label {
  font-size: 26rpx;
  color: #666;
}

.bottom-total .price {
  font-size: 44rpx;
}

.btn-submit {
  padding: 20rpx 60rpx;
}

/* 通知提醒卡片 */
.notify-card {
  background: #FFF8E1;
  border: 1rpx solid #FFE082;
}
.notify-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.notify-icon {
  font-size: 40rpx;
}
.notify-text {
  display: flex;
  flex-direction: column;
}
.notify-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.notify-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

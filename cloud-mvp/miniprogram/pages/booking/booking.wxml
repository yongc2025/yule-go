<!--pages/booking/booking.wxml-->
<!--预约下单页（含优惠券/余额/邀请立减/同行优惠）-->

<view class="page">
  <!-- 活动摘要 -->
  <view class="card summary-card">
    <view class="summary-name">{{info.activityName}}</view>
    <view class="summary-meta">
      <text>📅 {{info.scheduleDate}}</text>
      <text wx:if="{{info.shopName}}">🏪 {{info.shopName}}</text>
    </view>
  </view>

  <!-- 人数选择 -->
  <view class="card">
    <view class="section-title">👥 出行人数</view>

    <view class="counter-row">
      <view class="counter-label">
        <text>成人</text>
        <text class="counter-price">¥{{info.price}}/人</text>
      </view>
      <view class="counter-btns">
        <view class="counter-btn" bindtap="adjustAdults" data-delta="{{-1}}">−</view>
        <view class="counter-num">{{adults}}</view>
        <view class="counter-btn" bindtap="adjustAdults" data-delta="{{1}}">+</view>
      </view>
    </view>

    <view class="counter-row" wx:if="{{info.childPrice > 0}}">
      <view class="counter-label">
        <text>儿童</text>
        <text class="counter-price">¥{{info.childPrice}}/人</text>
      </view>
      <view class="counter-btns">
        <view class="counter-btn" bindtap="adjustChildren" data-delta="{{-1}}">−</view>
        <view class="counter-num">{{children}}</view>
        <view class="counter-btn" bindtap="adjustChildren" data-delta="{{1}}">+</view>
      </view>
    </view>
  </view>

  <!-- 邀请立减提示 -->
  <view class="card invite-card" wx:if="{{isFirstOrder && inviteDiscount > 0}}">
    <text class="invite-icon">🎁</text>
    <view class="invite-text">
      <text class="invite-title">好友邀请立减 ¥{{inviteDiscount}}</text>
      <text class="invite-desc">首次下单自动抵扣</text>
    </view>
  </view>

  <!-- 余额抵扣 -->
  <view class="card" wx:if="{{userBalance > 0}}">
    <view class="balance-row">
      <view class="balance-left">
        <text class="balance-icon">💰</text>
        <view class="balance-text">
          <text class="balance-label">余额抵扣</text>
          <text class="balance-amount">可用 ¥{{userBalance}}</text>
        </view>
      </view>
      <switch checked="{{useBalance}}" bindchange="toggleBalance" color="#2D6A4F" />
    </view>
  </view>

  <!-- 联系信息 -->
  <view class="card">
    <view class="section-title">📱 联系信息</view>
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{contactName}}" bindinput="onInputName" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{contactPhone}}" bindinput="onInputPhone" />
    </view>
  </view>

  <!-- 备注 -->
  <view class="card">
    <view class="section-title">💬 备注（选填）</view>
    <textarea class="remark-input" placeholder="有什么特殊需求可以写在这里" value="{{remark}}" bindinput="onInputRemark" maxlength="200" />
  </view>

  <!-- 费用明细 -->
  <view class="card">
    <view class="section-title">💰 费用明细</view>

    <!-- 优惠券选择（整合到费用明细） -->
    <view class="coupon-bar" bindtap="openCouponPicker">
      <view class="coupon-bar-left">
        <view class="coupon-badge">券</view>
        <text class="coupon-bar-label">优惠券</text>
      </view>
      <view class="coupon-bar-right">
        <block wx:if="{{selectedCoupon}}">
          <text class="coupon-bar-amount">-¥{{couponDiscount}}</text>
        </block>
        <block wx:elif="{{availableCoupons.length > 0}}">
          <text class="coupon-bar-count">{{availableCoupons.length}}张可用</text>
        </block>
        <block wx:else>
          <text class="coupon-bar-empty">暂无可用</text>
        </block>
        <text class="coupon-bar-arrow">›</text>
      </view>
    </view>

    <view class="fee-row">
      <text>原价小计</text>
      <text>¥{{originalFee}}</text>
    </view>

    <!-- 同行优惠 -->
    <view class="fee-row discount-row" wx:if="{{companionDiscount > 0}}">
      <view class="discount-label">
        <text class="discount-tag">🎁 同行优惠</text>
        <text class="discount-rule" wx:if="{{companionRule}}">{{companionRule}}</text>
      </view>
      <text class="discount-amount">-¥{{companionDiscount}}</text>
    </view>
    <view class="fee-row gift-row" wx:if="{{companionGift}}">
      <text class="gift-text">🎉 赠送：{{companionGift}}</text>
    </view>

    <!-- 会员立减（仅当会员折扣更优时） -->
    <view class="fee-row discount-row" wx:if="{{memberDiscount > 0 && discountType === 'member'}}">
      <view class="discount-label">
        <text class="discount-tag">👑 会员立减</text>
      </view>
      <text class="discount-amount">-¥{{memberDiscount}}</text>
    </view>

    <!-- 邀请立减 -->
    <view class="fee-row discount-row" wx:if="{{inviteDiscount > 0}}">
      <view class="discount-label">
        <text class="discount-tag">🤝 邀请立减</text>
      </view>
      <text class="discount-amount">-¥{{inviteDiscount}}</text>
    </view>

    <!-- 优惠券 -->
    <view class="fee-row discount-row" wx:if="{{couponDiscount > 0}}">
      <view class="discount-label">
        <text class="discount-tag">🎫 优惠券</text>
      </view>
      <text class="discount-amount">-¥{{couponDiscount}}</text>
    </view>

    <!-- 余额抵扣 -->
    <view class="fee-row discount-row" wx:if="{{balanceDeduction > 0}}">
      <view class="discount-label">
        <text class="discount-tag">💰 余额抵扣</text>
      </view>
      <text class="discount-amount">-¥{{balanceDeduction}}</text>
    </view>

    <view class="fee-row total">
      <text>实付金额</text>
      <text class="price">¥{{finalFee}}</text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view style="height: 140rpx;"></view>

  <!-- 底部提交栏 -->
  <view class="bottom-bar">
    <view class="bottom-total">
      <text class="bottom-label">实付：</text>
      <text class="price">¥{{finalFee}}</text>
    </view>
    <view class="btn-primary btn-submit {{submitting ? 'btn-disabled' : ''}}" bindtap="submitOrder">
      {{submitting ? '提交中...' : '确认支付'}}
    </view>
  </view>

  <!-- 优惠券选择弹窗 -->
  <view class="coupon-modal" wx:if="{{showCouponPicker}}" bindtap="closeCouponPicker">
    <view class="coupon-modal-content" catchtap="">
      <view class="coupon-modal-header">
        <text class="coupon-modal-title">选择优惠券</text>
        <text class="coupon-modal-close" bindtap="closeCouponPicker">✕</text>
      </view>

      <!-- 不使用优惠券 -->
      <view class="coupon-option {{!selectedCoupon ? 'coupon-selected' : ''}}" bindtap="clearCoupon">
        <text>不使用优惠券</text>
        <text class="coupon-check" wx:if="{{!selectedCoupon}}">✓</text>
      </view>

      <!-- 可用券列表 -->
      <scroll-view scroll-y class="coupon-scroll">
        <view class="coupon-option {{selectedCoupon._id === item._id ? 'coupon-selected' : ''}}"
              wx:for="{{availableCoupons}}" wx:key="_id"
              bindtap="selectCoupon" data-coupon="{{item}}">
          <view class="coupon-option-left">
            <view class="coupon-amount-tag">¥{{item.amount}}</view>
            <view class="coupon-option-info">
              <text class="coupon-option-type">{{item.typeName}}</text>
              <text class="coupon-option-desc">{{item.description}}</text>
            </view>
          </view>
          <text class="coupon-check" wx:if="{{selectedCoupon._id === item._id}}">✓</text>
        </view>
      </scroll-view>

      <view class="coupon-empty" wx:if="{{availableCoupons.length === 0}}">
        <text>暂无可用优惠券</text>
      </view>
    </view>
  </view>
</view>

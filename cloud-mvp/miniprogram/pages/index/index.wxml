<!--pages/index/index.wxml-->
<!--活动列表页 — 首页-->

<view class="page">
  <!-- 门店头部 -->
  <view class="shop-header">
    <view class="shop-info">
      <image class="shop-avatar" src="{{shopInfo.ownerAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="shop-text">
        <view class="shop-name">{{shopInfo.name || '渔乐出行'}}</view>
        <view class="shop-slogan">{{shopInfo.slogan || '周末去哪？跟我走！'}}</view>
      </view>
    </view>
    <view class="shop-tags">
      <view class="tag tag-blue">⭐ {{shopInfo.rating || '5.0'}}</view>
      <view class="tag tag-green">已服务{{shopInfo.serviceCount || 0}}人</view>
    </view>
  </view>

  <!-- 周选择器 -->
  <view class="week-selector">
    <view class="week-arrow" bindtap="prevWeek">◀</view>
    <view class="week-label" bindtap="backThisWeek">{{weekLabel}}</view>
    <view class="week-arrow" bindtap="nextWeek">▶</view>
  </view>

  <!-- 活动列表 -->
  <view class="activity-list" wx:if="{{activities.length > 0}}">
    <view class="activity-card" wx:for="{{activities}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <view class="activity-cover">
        <image src="{{item.coverImage || '/images/default-cover.png'}}" mode="aspectFill" />
        <view class="activity-type-badge">{{item.typeName}}</view>
      </view>
      <view class="activity-body">
        <view class="activity-title">{{item.name}}</view>
        <view class="activity-meta">
          <text class="activity-date">📅 {{item.dateFormatted}}</text>
          <text class="activity-slots {{item.slotsLeft <= 3 ? 'slots-warning' : ''}}">
            {{item.slotsLeft <= 0 ? '已满' : '余' + item.slotsLeft + '位'}}
          </text>
        </view>
        <view class="activity-footer">
          <view class="activity-price">
            <text class="price">¥{{item.price}}</text>
            <text class="price-unit">/人</text>
          </view>
          <view class="btn-book {{item.slotsLeft <= 0 ? 'btn-disabled' : ''}}">
            {{item.slotsLeft <= 0 ? '已满' : '报名'}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && activities.length === 0}}">
    <view class="empty-icon">🎣</view>
    <view>本周暂无活动安排</view>
    <view class="empty-sub">下来看看吧~</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>

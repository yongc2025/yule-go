/* pages/invite/invite.wxss */

.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 顶部邀请卡片 ========== */
.invite-header {
  position: relative;
  padding: 0 24rpx 24rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #2D6A4F, #40916C);
  border-radius: 0 0 48rpx 48rpx;
}

.invite-card {
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.15);
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #E76F51;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 邀请码 */
.code-box {
  background: #F0F9F4;
  border: 2rpx dashed #2D6A4F;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.code-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.code-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 8rpx;
  font-family: 'Courier New', monospace;
}

.btn-copy {
  background: #2D6A4F;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.btn-copy:active {
  opacity: 0.85;
}

/* 分享按钮 */
.btn-share {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #E76F51, #F4845F) !important;
  color: #fff !important;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  padding: 24rpx 0;
  border: none;
  line-height: 1;
}

.btn-share::after {
  border: none;
}

.share-icon {
  font-size: 32rpx;
}

/* ========== 奖励统计 ========== */
.stats-section {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #E76F51;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

/* ========== 活动规则 ========== */
.rules-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.rule-list {
  padding: 0 8rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-dot {
  width: 36rpx;
  height: 36rpx;
  background: #E8F5E9;
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-top: 4rpx;
}

/* ========== 邀请记录 ========== */
.records-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-list {
  margin-top: 8rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 22rpx;
  color: #bbb;
}

.record-reward {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.reward-status {
  font-size: 24rpx;
  font-weight: 600;
}

.reward-done {
  color: #E76F51;
}

.reward-pending {
  color: #999;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 加载状态 ========== */
.loading-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

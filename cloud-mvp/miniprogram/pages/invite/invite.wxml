<!--pages/invite/invite.wxml-->
<!--邀请好友 — 老带新裂变-->

<view class="page">
  <!-- 顶部邀请卡片 -->
  <view class="invite-header">
    <view class="header-bg"></view>
    <view class="invite-card">
      <view class="card-title">🎣 邀请好友一起钓鱼</view>
      <view class="card-desc">好友首单立减 ¥15，你赚 ¥20 余额</view>

      <!-- 邀请码 -->
      <view class="code-box">
        <view class="code-label">我的邀请码</view>
        <view class="code-row">
          <text class="code-text">{{inviteCode || '加载中...'}}</text>
          <view class="btn-copy" bindtap="copyCode">复制</view>
        </view>
      </view>

      <!-- 分享按钮 -->
      <button class="btn-share" open-type="share">
        <text class="share-icon">📤</text>
        <text>邀请好友</text>
      </button>
    </view>
  </view>

  <!-- 奖励统计 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-num">{{totalReward}}</text>
      <text class="stat-label">累计奖励(元)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{completedCount}}</text>
      <text class="stat-label">已邀请(人)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{pendingCount}}</text>
      <text class="stat-label">待完成(人)</text>
    </view>
  </view>

  <!-- 活动规则 -->
  <view class="rules-section">
    <view class="section-header">
      <text class="section-title">📌 活动规则</text>
    </view>
    <view class="rule-list">
      <view class="rule-item">
        <text class="rule-dot">1</text>
        <text class="rule-text">分享你的邀请码或邀请链接给好友</text>
      </view>
      <view class="rule-item">
        <text class="rule-dot">2</text>
        <text class="rule-text">好友通过邀请链接注册，自动绑定关系</text>
      </view>
      <view class="rule-item">
        <text class="rule-dot">3</text>
        <text class="rule-text">好友首次下单立减 ¥15</text>
      </view>
      <view class="rule-item">
        <text class="rule-dot">4</text>
        <text class="rule-text">好友首单支付成功后，你获得 ¥20 余额奖励</text>
      </view>
    </view>
  </view>

  <!-- 邀请记录 -->
  <view class="records-section">
    <view class="section-header">
      <text class="section-title">👥 邀请记录</text>
      <text class="section-count" wx:if="{{inviteList.length > 0}}">共{{inviteList.length}}人</text>
    </view>

    <view class="record-list" wx:if="{{inviteList.length > 0}}">
      <view class="record-item" wx:for="{{inviteList}}" wx:key="_id">
        <image class="record-avatar" src="{{item.inviteeAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="record-info">
          <view class="record-name">{{item.inviteeNickname}}</view>
          <view class="record-time">{{item.createdAtText}}</view>
        </view>
        <view class="record-reward">
          <text class="reward-status {{item.status === 'completed' ? 'reward-done' : 'reward-pending'}}">
            {{item.status === 'completed' ? '¥20 已到账' : '待完成'}}
          </text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && inviteList.length === 0}}">
      <text class="empty-icon">🤝</text>
      <text class="empty-text">还没有邀请记录</text>
      <text class="empty-hint">快去邀请好友一起钓鱼吧</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

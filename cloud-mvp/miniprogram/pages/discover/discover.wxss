/* pages/discover/discover.wxss */

.page {
  padding-bottom: 20rpx;
}

.page-header {
  padding: 32rpx 32rpx 16rpx;
  background: #fff;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1B1B1B;
}

.page-sub {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

/* 分类筛选 */
.filter-bar {
  display: flex;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F5F5F0;
  flex-shrink: 0;
}

.filter-item.active {
  background: #D8F3DC;
  color: #2D6A4F;
  font-weight: 600;
}

/* 门店卡片 */
.shop-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.shop-cover {
  position: relative;
  height: 160rpx;
  background: linear-gradient(135deg, #2D6A4F, #40916C);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.shop-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.shop-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.shop-body {
  padding: 24rpx;
}

.shop-name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.shop-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.shop-hot {
  font-size: 24rpx;
  color: #E76F51;
  margin-bottom: 16rpx;
}

.shop-action {
  display: flex;
  justify-content: flex-end;
}

.btn-go {
  background: #2D6A4F;
  color: #fff;
  padding: 12rpx 40rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

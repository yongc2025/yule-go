<!--pages/profile/profile.wxml-->
<!--我的 — 个人中心（云端数据 + 简介 + 相册预览）-->

<view class="page">
  <!-- 用户卡片 -->
  <view class="user-card" bindtap="goEdit">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <view class="user-name">{{userInfo.nickName || '钓鱼爱好者'}}</view>
      <view class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</view>
      <view class="user-tag" wx:else>🎣 渔乐会员</view>
    </view>
    <text class="edit-arrow">✏️</text>
  </view>

  <!-- 个人相册预览 -->
  <view class="section" wx:if="{{userInfo.album && userInfo.album.length > 0}}">
    <view class="section-header">
      <text class="section-title">📷 个人相册</text>
      <text class="section-link" bindtap="goEdit">查看全部 →</text>
    </view>
    <scroll-view class="album-scroll" scroll-x>
      <view class="album-item" wx:for="{{userInfo.album}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="album-img" />
      </view>
    </scroll-view>
  </view>

  <!-- 我的门店 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🏪 我的门店</text>
    </view>
    <view class="shop-list" wx:if="{{myShops.length > 0}}">
      <view class="shop-item" wx:for="{{myShops}}" wx:key="_id">
        <image class="shop-avatar" src="{{item.ownerAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="shop-info">
          <view class="shop-name">{{item.name}}</view>
          <view class="shop-wallet">
            <text class="wallet-level" wx:if="{{item.wallet.memberLevel > 0}}">
              {{item.wallet.memberLevel >= 3 ? '💎' : item.wallet.memberLevel >= 2 ? '🥇' : '🥈'}} {{item.wallet.memberName}}
            </text>
            <text class="wallet-balance">余额 ¥{{item.wallet.balance}}</text>
          </view>
          <view class="shop-meta" wx:if="{{item.wallet.travelDiscount > 0}}">每次出行立减 ¥{{item.wallet.travelDiscount}}</view>
        </view>
        <view class="shop-actions">
          <view class="btn-records-sm" catchtap="goRecords" data-shopid="{{item._id}}">记录</view>
          <view class="btn-recharge-sm" catchtap="goRecharge" data-shopid="{{item._id}}">充值</view>
        </view>
      </view>
    </view>
    <view class="empty-sub" wx:else>还没有去过任何门店~</view>
  </view>

  <!-- 快捷入口 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goCoupons">
      <text class="menu-icon">🎫</text>
      <text class="menu-text">我的优惠券</text>
      <view class="menu-badge" wx:if="{{couponCount > 0}}">{{couponCount}}</view>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goAdmin">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">店主管理</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="callService">
      <text class="menu-icon">📞</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goDiscover">
      <text class="menu-icon">🔍</text>
      <text class="menu-text">发现新门店</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>
</view>

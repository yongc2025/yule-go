/* pages/profile/edit.wxss */

.page { background: #f5f5f5; min-height: 100vh; }

.section {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.section-hint { font-size: 24rpx; color: #999; font-weight: 400; }

/* 头像行 */
.avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.avatar-right { display: flex; align-items: center; gap: 16rpx; }
.avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid #eee;
}
.arrow { color: #ccc; font-size: 28rpx; }

/* 表单 */
.form-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}
.form-input {
  font-size: 28rpx;
  padding: 8rpx 0;
  width: 100%;
}
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
  padding: 12rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  box-sizing: border-box;
}
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 4rpx;
}

/* 手机号 */
.phone-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.phone-text { font-size: 28rpx; color: #333; }
.phone-bind { padding: 12rpx 0; }
.btn-phone {
  background: #2D6A4F;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 20rpx;
}
.btn-phone-mini {
  background: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}
.phone-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 0;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e0e0e0;
}
.divider-text {
  font-size: 24rpx;
  color: #999;
}
.phone-manual {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.flex1 { flex: 1; }
.btn-bind {
  background: #2D6A4F;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

/* 相册 */
.album-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.album-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.album-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.album-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.album-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.add-icon { font-size: 48rpx; color: #999; }
.add-text { font-size: 24rpx; color: #999; }

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
.btn-save {
  background: #2D6A4F;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}
.btn-save.disabled { opacity: 0.6; }

/* pages/profile/profile.wxss */

.page {
  padding-bottom: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #2D6A4F, #40916C);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.user-bio {
  font-size: 24rpx;
  opacity: 0.85;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-tag {
  font-size: 24rpx;
  opacity: 0.85;
}

.edit-arrow {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 相册预览 */
.album-scroll {
  white-space: nowrap;
  margin-top: 12rpx;
}
.album-item {
  display: inline-block;
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.album-img {
  width: 100%;
  height: 100%;
}

/* 通用 section */
.section {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.section-link {
  font-size: 24rpx;
  color: #2D6A4F;
}

.shop-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.shop-item:last-child {
  border-bottom: none;
}

.shop-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.shop-primary {
  font-size: 22rpx;
  color: #E76F51;
  margin-left: 8rpx;
}

.shop-meta {
  font-size: 24rpx;
  color: #6B7280;
}

.shop-wallet {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.wallet-level {
  font-size: 22rpx;
  color: #2D6A4F;
  font-weight: 600;
  background: #E8F5E9;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

.wallet-balance {
  font-size: 24rpx;
  color: #E76F51;
  font-weight: 600;
}

.shop-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-records-sm {
  background: #f5f5f5;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.btn-recharge-sm {
  background: linear-gradient(135deg, #E76F51, #F4845F);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.shop-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 快捷入口 */
.menu-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
}

.menu-badge {
  background: #E76F51;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 999rpx;
  padding: 0 8rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

.empty-sub {
  color: #999;
  font-size: 26rpx;
  text-align: center;
  padding: 24rpx 0;
}

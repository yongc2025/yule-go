/* pages/coupons/list.wxss */

.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-active {
  color: #2D6A4F;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #2D6A4F;
  border-radius: 3rpx;
}

/* 券列表 */
.coupon-list {
  padding: 24rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.coupon-disabled {
  opacity: 0.55;
}

/* 左侧面额 */
.coupon-left {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background: linear-gradient(135deg, #E76F51, #F4845F);
  color: #fff;
}

.coupon-amount {
  display: flex;
  align-items: baseline;
}

.coupon-yen {
  font-size: 28rpx;
  font-weight: 600;
}

.coupon-num {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.coupon-special .coupon-num-sm {
  font-size: 28rpx;
  font-weight: 700;
}

.coupon-condition {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

/* 分割线 */
.coupon-divider {
  width: 1rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coupon-notch {
  width: 24rpx;
  height: 12rpx;
  background: #f5f5f5;
  border-radius: 0 0 12rpx 12rpx;
}

.coupon-notch.top {
  border-radius: 0 0 12rpx 12rpx;
  position: absolute;
  top: -1rpx;
}

.coupon-notch.bottom {
  border-radius: 12rpx 12rpx 0 0;
  position: absolute;
  bottom: -1rpx;
}

.coupon-dots {
  flex: 1;
  width: 0;
  border-left: 2rpx dashed #e0e0e0;
}

/* 右侧信息 */
.coupon-right {
  flex: 1;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #E76F51;
  background: #FFF8F0;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 10rpx;
  align-self: flex-start;
}

.coupon-desc {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #bbb;
}

/* 状态角标 */
.coupon-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.badge-used {
  color: #999;
  background: #f0f0f0;
}

.badge-expired {
  color: #ccc;
  background: #f5f5f5;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

/* pages/orders/orders.wxss */

.status-tabs {
  display: flex;
  background: #fff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #2D6A4F;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: #2D6A4F;
  border-radius: 2rpx;
}

.order-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
}

.order-no {
  color: #999;
}

.order-status {
  font-weight: 600;
}

.status-pending {
  color: #E76F51;
}

.status-paid {
  color: #2D6A4F;
}

.status-completed {
  color: #2D6A4F;
}

.status-cancelled {
  color: #999;
}

.status-refunding {
  color: #fa541c;
}

.order-body {
  padding: 24rpx;
}

.order-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.order-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #666;
}

.order-footer {
  padding: 16rpx 24rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-amount {
  margin-bottom: 16rpx;
}

.order-amount .price {
  font-size: 36rpx;
}

/* 核销码 */
.checkin-section {
  background: #D8F3DC;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.checkin-code {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.qrcode-canvas {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn-outline {
  padding: 12rpx 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.btn-primary-sm {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #2D6A4F, #40916C);
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}
